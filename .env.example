# Supabase Postgres pooler connection string (pgBouncer, port 6543)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-region.pooler.supabase.com:6543/postgres

# Supabase project URL and publishable/anon key (Project Settings > API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxx

# Allowed admin GitHub numeric id (single-admin gate)
ALLOWED_GH_ID=your_github_numeric_id

# Secret Vercel injects into cron requests (auto-set by Vercel, add manually for local testing)
CRON_SECRET=your_cron_secret
