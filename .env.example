# DatoCMS read-only token for fetching content (projects, skills)
# Get it from: https://www.datocms.com/ > Project Settings > API Tokens
DATOCMS_READONLY_TOKEN=your_datocms_readonly_token_here

# DatoCMS full-access token for managing models and content (not needed at runtime)
DATOCMS_FULL_ACCESS_TOKEN=your_datocms_full_access_token_here
